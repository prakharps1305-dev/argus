# Copy this file to .env and fill in your values:  cp .env.example .env

# ---- Required ----
# SigNoz API key — create in SigNoz UI: Settings -> API Keys -> New Key (ADMIN role).
SIGNOZ_API_KEY=your-signoz-admin-api-key-here

# SigNoz API URL as seen from INSIDE a Docker container (the MCP server).
# On Docker Desktop, host.docker.internal points at your machine's localhost.
SIGNOZ_URL=http://host.docker.internal:8080

# ---- Optional (sensible defaults; override to deploy elsewhere) ----
# LLM endpoint — any OpenAI-compatible API. Default: local Ollama.
#   e.g. OpenAI:   LLM_BASE_URL=https://api.openai.com/v1  LLM_API_KEY=sk-...  LLM_MODEL=gpt-4o-mini
#   e.g. Groq:     LLM_BASE_URL=https://api.groq.com/openai/v1  LLM_API_KEY=gsk_...  LLM_MODEL=llama-3.1-70b-versatile
# LLM_BASE_URL=http://host.docker.internal:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=qwen3:8b

# Where the agent ships its OWN telemetry (SigNoz OTLP HTTP).
# TRACELOOP_BASE_URL=http://host.docker.internal:4318

# Public SigNoz URL for the "view trace" link shown in the web UI (browser-facing).
# SIGNOZ_WEB_URL=http://localhost:8080

# MCP server URL as seen by the agent (compose sets this automatically).
# MCP_URL=http://localhost:8000/mcp
