# Copy this file to .env and fill in your values:  cp .env.example .env
#
# SigNoz API key — create in SigNoz UI: Settings -> API Keys -> New Key (ADMIN role).
SIGNOZ_API_KEY=your-signoz-admin-api-key-here
#
# SigNoz API URL as seen from INSIDE a Docker container (the MCP server runs in Docker).
# On Docker Desktop, host.docker.internal points at your machine's localhost.
SIGNOZ_URL=http://host.docker.internal:8080
